# ============================================================
# Apeiron Data Sentinel — Environment Configuration
# Copy to .env and adjust values for your environment
# ============================================================

# --- General ---
ENVIRONMENT=development
APP_NAME="Apeiron Data Sentinel"
APP_VERSION=0.1.0
DEBUG=true

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# --- PostgreSQL ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secure_pwd_change_me
POSTGRES_DB=apeiron_sentinel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PG_SHARED_BUFFERS=8GB
PG_WORK_MEM=256MB
PG_MAX_CONNECTIONS=200

# --- PgBouncer ---
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=300
PGBOUNCER_DEFAULT_POOL_SIZE=50

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- File Upload ---
UPLOAD_MAX_SIZE_MB=100
UPLOAD_DIR=/app/uploads

# --- Ollama (GRACE AI) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Logging ---
LOG_LEVEL=INFO
